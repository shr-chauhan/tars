# ── Anthropic (Claude) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant...
OPENAI_API_KEY=sk-proj...
# Get these from Azure Portal > App Registrations > your bot app
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_TENANT_ID=
# MICROSOFT_SECRET_ID = eb3f0be4-f51d-4d94-9ce4-ce66e76f2714
# ── Linear ────────────────────────────────────────────
# Get from: Linear > Settings > API > Personal API keys
LINEAR_API_KEY=lin_api_...

# ── GitHub ────────────────────────────────────────────
# Create at: GitHub > Settings > Developer Settings > Personal Access Tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=github_pat_...
# GITHUB_ORG=
GITHUB_DEFAULT_REPO=owner/repo

# ── Outlook (Microsoft Graph) ─────────────────────────
# The mailbox TARS will read. Must be a UPN in the same Azure tenant.
# Requires Mail.Read application permission + admin consent on the App Registration.
OUTLOOK_USER_EMAIL=you@yourcompany.com

# ── Server ────────────────────────────────────────────
PORT=